{
  "name": "unity-mcp-ts",
  "version": "2.1.0",
  "main": "build/index.js",
  "type": "module",
  "bin": {
    "unity-mcp": "./build/index.js"
  },
  "scripts": {
    "clean": "node -e \"import('node:fs/promises').then(fs => fs.rm('build', {recursive:true, force:true}))\"",
    "build": "npm run clean && tsc",
    "start": "node build/index.js",
    "dev": "tsx src/index.ts",
    "test": "node --experimental-vm-modules node_modules/jest/bin/jest.js",
    "lint": "eslint src --ext .ts",
    "lint:fix": "eslint src --ext .ts --fix"
  },
  "keywords": [
    "unity",
    "mcp",
    "claude",
    "ai"
  ],
  "author": "",
  "license": "ISC",
  "description": "Unity Model Context Protocol integration",
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.11.0",
    "zod": "^3.24.2"
  },
  "devDependencies": {
    "@jest/globals": "^29.7.0",
    "@types/jest": "^29.5.12",
    "@types/node": "^22.13.10",
    "eslint": "^8.57.0",
    "eslint-config-standard-with-typescript": "^43.0.1",
    "jest": "^29.7.0",
    "ts-jest": "^29.1.2",
    "tsx": "^4.19.3",
    "typescript": "^5.8.2",
    "undici": "^6.19.8",
    "vitest": "^3.0.8"
  }
}
